# AWS DocumentDB instance-based cluster connection
# Replace with your actual cluster endpoint and credentials
# Note: URL-encode special characters in password (e.g. # → %23)
DOCDB_URI=mongodb://<username>:<password>@<cluster-endpoint>:27017/?tls=true&tlsCAFile=global-bundle.pem&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false
DOCDB_DB_NAME=appdb

# Path to the AWS global CA bundle (download from AWS)
# https://truststore.pki.us-east-1.amazonaws.com/global/global-bundle.pem
TLS_CA_FILE=global-bundle.pem

SERVER_PORT=8080
